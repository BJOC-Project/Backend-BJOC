{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": ["node"],
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/app.ts",
    "src/server.ts",
    "src/config/**/*.ts",
    "src/database/**/*.ts",
    "src/errors/**/*.ts",
    "src/library/**/*.ts",
    "src/middleware/**/*.ts",
    "src/modules/auth/**/*.ts",
    "src/modules/admin/**/*.ts",
    "src/modules/drivers/**/*.ts",
    "src/modules/passenger/**/*.ts",
    "src/modules/staff/**/*.ts",
    "src/modules/users/**/*.ts",
    "src/modules/health/**/*.ts",
    "src/types/**/*.d.ts",
    "src/utils/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "src/tests",
    "src/modules/activityLogs/**/*",
    "src/modules/notifications/**/*",
    "src/modules/operators/**/*",
    "src/modules/reports/**/*",
    "src/modules/routes/**/*",
    "src/modules/stops/**/*",
    "src/modules/trips/**/*",
    "src/modules/verification/**/*",
    "src/modules/vehicles/**/*",
    "src/config/supabase.ts"
  ]
}
